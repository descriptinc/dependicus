{{#if hasVersionsBetween}}
<section>
    <h2>Upgrade Path</h2>
    <p>
        You are on <code>{{currentVersion}}</code>,
        latest is <code>{{latestVersion}}</code>
        ({{versionCount}} version{{#if (gt versionCount 1)}}s{{/if}} behind).
        {{#if compareUrl}}<a href="{{compareUrl}}">View full diff on GitHub</a>{{/if}}
    </p>

    <details class="dep-plain-details" open>
        <summary>Version History ({{versionCount}} versions)</summary>
        <div class="dep-version-history-grid" style="--grid-cols: auto{{#if hasPublishDates}} auto{{/if}}{{#if hasSizes}} auto{{/if}}{{#if hasLinks}} 1fr{{/if}};">
            <div class="dep-version-header">Version</div>
            {{#if hasPublishDates}}<div class="dep-version-header">Released</div>{{/if}}
            {{#if hasSizes}}<div class="dep-version-header">Size</div>{{/if}}
            {{#if hasLinks}}<div class="dep-version-header">Links</div>{{/if}}

            {{#each versions}}
            <div class="dep-version-cell">
                <code>{{version}}</code>
                {{#if isLatest}} <strong>(latest)</strong>{{/if}}
            </div>
            {{#if ../hasPublishDates}}<div class="dep-version-cell">{{formattedPublishDate}}</div>{{/if}}
            {{#if ../hasSizes}}
            <div class="dep-version-cell">
                {{#if formattedSize}}
                    {{formattedSize}}
                    {{#if sizeChange}}
                        <span class="dep-size-change {{#if sizeIncreased}}dep-size-increase{{/if}}{{#if sizeDecreased}}dep-size-decrease{{/if}}">
                            ({{sizeChange}})
                        </span>
                    {{/if}}
                {{/if}}
            </div>
            {{/if}}
            {{#if ../hasLinks}}
            <div class="dep-version-cell">
                {{#if registryUrl}}<a href="{{registryUrl}}">Registry</a>{{/if}}
                {{#if githubUrl}} | <a href="{{githubUrl}}">GitHub</a>{{/if}}
            </div>
            {{/if}}

            {{#if releaseNotes}}
            <div class="dep-version-notes">
                <details class="dep-plain-details">
                    <summary>Release notes</summary>
                    <div class="dep-release-notes-content dep-flow">{{{releaseNotes}}}</div>
                </details>
            </div>
            {{/if}}
            {{/each}}
        </div>
    </details>
</section>
{{/if}}
