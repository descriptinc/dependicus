{
    "name": "dependicus",
    "version": "0.1.11-rc.0",
    "description": "Dependency governance for monorepos: pnpm, bun, yarn, npm, aube, mise, uv, Go, and Rust",
    "keywords": [
        "audit",
        "dashboard",
        "dependency",
        "governance",
        "monorepo",
        "outdated"
    ],
    "homepage": "https://github.com/descriptinc/dependicus",
    "bugs": "https://github.com/descriptinc/dependicus/issues",
    "license": "MIT",
    "author": "Descript, Inc.",
    "repository": {
        "type": "git",
        "url": "https://github.com/descriptinc/dependicus.git",
        "directory": "packages/dependicus"
    },
    "bin": "dist/bin.mjs",
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "source": "./src/index.ts",
            "default": "./dist/index.mjs"
        }
    },
    "publishConfig": {
        "access": "public",
        "devDependencies": {
            "@types/node": "^25.3.0",
            "dts-bundle-generator": "^9.5.1",
            "rolldown": "1.0.0-rc.10",
            "tsdown": "^0.20.3",
            "typedoc": "^0.28.17",
            "typescript": "^5.9.3",
            "vitest": "^4.1.0"
        }
    },
    "scripts": {
        "dependicus": "node dist/bin.mjs",
        "build": "tsdown",
        "bundle": "node scripts/bundle.mjs",
        "prepack": "pnpm run build && pnpm run bundle",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "typedoc": "typedoc --tsconfig tsconfig.typedoc.json --entryPoints src/index.ts --out typedoc-out --name 'Dependicus API Reference'",
        "typecheck": "tsc --build tsconfig.json"
    },
    "dependencies": {
        "@linear/sdk": "^76.0.0",
        "@octokit/rest": "^22.0.1",
        "commander": "^14.0.3",
        "handlebars": "^4.7.8",
        "isomorphic-dompurify": "^3.5.1",
        "js-yaml": "^4.1.1",
        "marked": "^17.0.3",
        "open-props": "^1.7.23",
        "semver": "^7.7.4",
        "tabulator-tables": "^6.3.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@dependicus/core": "workspace:*",
        "@dependicus/github-issues": "workspace:*",
        "@dependicus/linear": "workspace:*",
        "@dependicus/provider-go": "workspace:*",
        "@dependicus/provider-mise": "workspace:*",
        "@dependicus/provider-rust": "workspace:*",
        "@dependicus/providers-node": "workspace:*",
        "@dependicus/providers-python": "workspace:*",
        "@dependicus/site-builder": "workspace:*",
        "@types/node": "^25.3.0",
        "dts-bundle-generator": "^9.5.1",
        "rolldown": "1.0.0-rc.10",
        "tsdown": "^0.20.3",
        "typedoc": "^0.28.17",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    }
}
