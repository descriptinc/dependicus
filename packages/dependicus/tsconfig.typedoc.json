{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "lib": ["ES2022", "DOM"],
        "paths": {
            "@dependicus/core": ["../core/src/index.ts"],
            "@dependicus/linear": ["../linear/src/index.ts"],
            "@dependicus/site-builder": ["../site-builder/src/index.ts"],
            "@dependicus/site-frontend": ["../site-frontend/src/index.ts"],
            "@dependicus/github-issues": ["../github-issues/src/index.ts"]
        }
    },
    "include": [
        "src/**/*",
        "../core/src/**/*",
        "../linear/src/**/*",
        "../site-builder/src/**/*",
        "../site-frontend/src/**/*",
        "../github-issues/src/**/*"
    ],
    "exclude": ["node_modules", "dist"]
}
